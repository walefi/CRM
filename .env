NODE_ENV=development

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
WEB_PORT=3000
WEB_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/crm_db?schema=public
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_DB=crm_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encryption
ENCRYPTION_KEY=32-char-encryption-key-here!!

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# BullMQ
BULL_QUEUE_PREFIX=crm

# PgAdmin
PGADMIN_EMAIL=admin@crm.com
PGADMIN_PASSWORD=Admin@123
PGADMIN_PORT=5050
