enum WebhookEvent {
  DEAL_CREATED
  DEAL_UPDATED
  DEAL_DELETED
  LEAD_CREATED
  LEAD_UPDATED
  CONTACT_CREATED
  TASK_COMPLETED
  USER_CREATED
  COMPANY_CREATED
  CONTRACT_SIGNED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  INACTIVE
  PUBLISHED
  ERROR
}

enum WorkflowNodeType {
  TRIGGER
  CONDITION
  DELAY
  IF
  ELSE
  LOOP
  SWITCH
  WAIT
