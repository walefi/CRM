  isEnabled    Boolean     @default(true)
  automationId String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([type])
  @@map("triggers")
}

model Condition {
  id           String            @id @default(uuid())
  field        String
  operator     ConditionOperator @default(EQUALS)
  value        String
  logic        String            @default("AND")
  groupId      String?
  sortOrder    Int               @default(0)
  automationId String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("conditions")
}

model Action {
  id           String     @id @default(uuid())
  type         ActionType
  config       Json?
  sortOrder    Int        @default(0)
  delay        Int        @default(0)
  isEnabled    Boolean    @default(true)
  automationId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@map("actions")
}

model AutomationExecution {
  id            String    @id @default(uuid())
  status        String    @default("pending")
  trigger       String?
  input         Json?
  result        Json?
  error         String?
  duration      Int?
  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)
  correlationId String?
  startedAt     DateTime?
  completedAt   DateTime?
  automationId  String
  workflowId    String?
  tenantId      String
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([tenantId])
  @@index([status])
  @@index([correlationId])
  @@index([createdAt])
  @@map("automation_executions")
}

model AutomationSchedule {
  id             String            @id @default(uuid())
  name           String
  frequency      ScheduleFrequency @default(ONCE)
  cronExpression String?
  interval       Int?
  startAt        DateTime?
  endAt          DateTime?
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  timezone       String            @default("America/Sao_Paulo")
  isEnabled      Boolean           @default(true)
  config         Json?
  automationId   String
  tenantId       String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@index([automationId])
  @@index([tenantId])
  @@index([nextRunAt])
  @@map("automation_schedules")
}

model AutomationLog {
  id           String             @id @default(uuid())
