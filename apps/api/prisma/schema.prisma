// ══════════════════════════════════════════════
// CRM Enterprise — Complete Database Schema
// ══════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
  PENDING
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL_MARKETING
  COLD_CALL
  TRADE_SHOW
  PARTNER
  OTHER
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  NOTE
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DealCurrency {
  BRL
  USD
  EUR
  GBP
  JPY
  CNY
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ERROR
  PAUSED
  RUNNING
}

enum TriggerType {
  DEAL_CREATED
  DEAL_UPDATED
  LEAD_CREATED
  LEAD_CONVERTED
  TASK_COMPLETED
  CONTACT_CREATED
  FORM_SUBMITTED
  WEBHOOK
  SCHEDULED
  COMPANY_CREATED
  CONTRACT_SIGNED
  DOCUMENT_SENT
  ACTIVITY_CREATED
  USER_CREATED
  LOGIN
  CRON
  MANUAL
  API
  LEAD_UPDATED
  DEAL_WON
  DEAL_LOST
  PRODUCT_CREATED
  CONTRACT_CREATED
  CONTRACT_EXPIRING
  CONTRACT_RENEWED
  QUOTE_SENT
  QUOTE_ACCEPTED
  DOCUMENT_SHARED
  ACTIVITY_COMPLETED
  NOTIFICATION_SENT
  WORKFLOW_COMPLETED
  LOGOUT
  WEBHOOK_RECEIVED
  API_CALLED
  CUSTOM_EVENT
}

enum ActionType {
  SEND_EMAIL
  CREATE_TASK
  UPDATE_DEAL
  SEND_NOTIFICATION
  WEBHOOK
  UPDATE_CONTACT
  MOVE_PIPELINE
  CREATE_LEAD
  CREATE_CONTACT
  CREATE_COMPANY
  CREATE_DEAL
  CREATE_ACTIVITY
  SEND_WHATSAPP
  SEND_PUSH
  CREATE_DOCUMENT
  UPDATE_FIELDS
  EXECUTE_AI
  EXECUTE_API
  CREATE_PRODUCT
  SEND_SMS
  EXECUTE_WORKFLOW
  CREATE_TIMELINE
  CREATE_AUDIT
  CREATE_COMMENT
  CREATE_TAG
  ADD_FILE
  EXECUTE_SCRIPT
}

enum ScheduleFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CRON
  INTERVAL
  AFTER_EVENT
}

enum AutomationLogLevel {
  INFO
  WARN
  ERROR
  DEBUG
  TRACE
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  GREATER_THAN
  LESS_THAN
  GREATER_OR_EQUAL
  LESS_OR_EQUAL
  CONTAINS
  NOT_CONTAINS
  STARTS_WITH
  ENDS_WITH
  IS_EMPTY
  IS_NOT_EMPTY
  IN
  NOT_IN
  BETWEEN
  REGEX
  BEFORE
  AFTER
  IS_TRUE
  IS_FALSE
}

enum WebhookEvent {
  DEAL_CREATED
  DEAL_UPDATED
  DEAL_DELETED
  LEAD_CREATED
  LEAD_UPDATED
  CONTACT_CREATED
  TASK_COMPLETED
  USER_CREATED
  COMPANY_CREATED
  CONTRACT_SIGNED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  INACTIVE
  PUBLISHED
  ERROR
}

enum WorkflowNodeType {
  TRIGGER
  CONDITION
  DELAY
  IF
  ELSE
  LOOP
  SWITCH
  WAIT
  WEBHOOK
  EMAIL
  WHATSAPP
  SMS
  PUSH
  SLACK
  TEAMS
  DISCORD
  TELEGRAM
  HTTP_REQUEST
  DATABASE
  SCRIPT
  AI
  END
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
  RETRYING
  DEAD_LETTER
}

enum ChannelType {
  EMAIL
  CHAT
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  PHONE
  SMS
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum WidgetType {
  CHART
  METRIC
  TABLE
  PIPELINE
  LIST
  CALENDAR
  KPI_CARD
  LINE_CHART
  BAR_CHART
  PIE_CHART
  DONUT_CHART
  AREA_CHART
  RADAR_CHART
  FUNNEL_CHART
  HEATMAP
  GAUGE
  TIMELINE
  RANKING
}

enum QuoteStatus {
  DRAFT
  UNDER_REVIEW
  SENT
  VIEWED
  NEGOTIATION
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum ContractStatus {
  DRAFT
  UNDER_REVIEW
  AWAITING_SIGNATURE
  SIGNED
  ACTIVE
  SUSPENDED
  CANCELLED
  TERMINATED
  EXPIRED
  ARCHIVED
}

enum ContractType {
  SERVICE
  SALE
  RENTAL
  LICENSING
  SUBSCRIPTION
  MAINTENANCE
  SUPPORT
  SLA
  CUSTOM
}

enum SignerStatus {
  PENDING
  SENT
  VIEWED
  SIGNED
  REFUSED
  EXPIRED
}

// ═══════════════════════════════════════
// CORE
// ═══════════════════════════════════════

model Tenant {
  id        String           @id @default(uuid())
  name      String
  slug      String           @unique
  domain    String?
  logo      String?
  plan      SubscriptionPlan @default(FREE)
  status    TenantStatus     @default(TRIAL)
  settings  Json?            @default("{}")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  users             User[]
  roles             Role[]
  permissions       Permission[]
  teams             Team[]
  departments       Department[]
  companies         Company[]
  contacts          Contact[]
  leads             Lead[]
  customers         Customer[]
  deals             Deal[]
  pipelines         Pipeline[]
  products          Product[]
  categories        Category[]
  tasks             Task[]
  automations       Automation[]
  integrations      Integration[]
  apiKeys           ApiKey[]
  emailTemplates    EmailTemplate[]
  sessions          Session[]
  settings_         Setting[]
  dashboards        Dashboard[]
  reports           Report[]
  audits            AuditLog[]
  notifications     Notification[]
  customFields      CustomField[]
  tags_             Tag[]
  files             File[]
  conversations     Conversation[]
  channels          Channel[]
  calendars         Calendar[]
  whatsappAccounts  WhatsAppAccount[]
  instagramAccounts InstagramAccount[]
  facebookAccounts  FacebookAccount[]
  aiConversations   AIConversation[]
  aiTasks           AITask[]
  aiPrompts         AIPrompt[]
  Quote             Quote[]
  Contract          Contract[]
  Activity          Activity[]
  Note              Note[]
  Timeline          Timeline[]
  History           History[]
  Attachment        Attachment[]
  Message           Message[]
  CustomFieldGroup  CustomFieldGroup[]
  Workflow         Workflow[]
  WorkflowVersion  WorkflowVersion[]
  WorkflowExecution WorkflowExecution[]
  EventStore       EventStore[]
  DeadLetter       DeadLetter[]
  AutomationSchedule AutomationSchedule[]
  AutomationLog    AutomationLog[]
  AutomationVariable AutomationVariable[]
  AutomationTemplate AutomationTemplate[]
  SearchIndex     SearchIndex[]
  SearchDocument  SearchDocument[]
  SearchHistory   SearchHistory[]
  SearchFavorite  SearchFavorite[]
  SearchSavedFilter SearchSavedFilter[]
  AnalyticsEvent  AnalyticsEvent[]
  MetricSnapshot  MetricSnapshot[]
  DashboardTemplate DashboardTemplate[]
  Widget          Widget[]
  ReportExecution ReportExecution[]
  ReportSchedule  ReportSchedule[]
  ReportTemplate  ReportTemplate[]
  ReportExport    ReportExport[]
  IntegrationConnection IntegrationConnection[]
  IntegrationWebhook IntegrationWebhook[]
  IntegrationLog   IntegrationLog[]
  IntegrationSync  IntegrationSync[]
  AIMemory         AIMemory[]
  AIAgent          AIAgent[]
  AIEmbedding      AIEmbedding[]
  AIUsage          AIUsage[]
  ConversationQueue ConversationQueue[]
  MessageTemplate  MessageTemplate[]
  Ticket           Ticket[]
  KnowledgeArticle KnowledgeArticle[]
  TimelineBookmark TimelineBookmark[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  password        String
  firstName       String
  lastName        String
  avatar          String?
  phone           String?
  title           String?
  timezone        String     @default("America/Sao_Paulo")
  language        String     @default("pt-BR")
  status          UserStatus @default(INVITED)
  role            String     @default("user")
  lastLoginAt     DateTime?
  lastLoginIp     String?
  refreshToken    String?
  resetToken      String?
  resetTokenExp   DateTime?
  emailVerifiedAt DateTime?
  tenantId        String
  teamId          String?
  departmentId    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  team            Team?          @relation("TeamMembers", fields: [teamId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])
  assignedTasks   Task[]         @relation("AssignedTasks")
  createdTasks    Task[]         @relation("CreatedTasks")
  ownedCompanies  Company[]      @relation("CompanyOwner")
  ownedContacts   Contact[]      @relation("ContactOwner")
  ownedLeads      Lead[]         @relation("LeadOwner")
  ownedDeals      Deal[]         @relation("DealOwner")
  ownedCustomers  Customer[]     @relation("CustomerOwner")
  ownedProducts   Product[]      @relation("ProductOwner")
  ownedQuotes     Quote[]        @relation("QuoteOwner")
  ownedContracts  Contract[]     @relation("ContractOwner")
  notes           Note[]
  activities      Activity[]
  sessions        Session[]
  refreshTokens   RefreshToken[]
  audits          AuditLog[]
  notifications   Notification[]
  dashboards      Dashboard[]
  reports         Report[]
  conversations   Conversation[]
  events          Event[]
  timelineEntries Timeline[]
  historyEntries  History[]
  sentMessages    Message[]      @relation("SenderMessages")
  leadingTeams    Team[]         @relation("TeamLead")
  TaskComment     TaskComment[]

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([teamId])
  @@index([departmentId])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String
  slug        String
  description String?
  isSystem    Boolean  @default(false)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions RolePermission[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String
  slug        String
  resource    String
  action      String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  roles  RolePermission[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Team {
  id          String    @id @default(uuid())
  name        String
  description String?
  tenantId    String
  leadId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   User?  @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  users     User[] @relation("TeamMembers")
  quotes    Quote[]
  contracts Contract[]

  @@index([tenantId])
  @@index([leadId])
  @@map("teams")
}

model Department {
  id          String    @id @default(uuid())
  name        String
  description String?
  parentId    String?
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  parent   Department?  @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Department[] @relation("DeptHierarchy")
  users    User[]

  @@index([tenantId])
  @@index([parentId])
  @@map("departments")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  token     String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════
// CRM
// ═══════════════════════════════════════

model Company {
  id          String    @id @default(uuid())
  name        String
  legalName   String?
  cnpj        String?
  website     String?
  industry    String?
  size        String?
  revenue     Decimal?  @db.Decimal(15, 2)
  employees   Int?
  phone       String?
  email       String?
  address     Json?
  logo        String?
  description String?
  tenantId    String
  ownerId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  owner    User?      @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contacts Contact[]
  quotes   Quote[]
  contracts Contract[]
  leads    Lead[]
  deals    Deal[]
  tasks    Task[]
  notes    Note[]
  files    File[]
  Activity Activity[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([name])
  @@index([cnpj])
  @@index([deletedAt])
  @@map("companies")
}

model Contact {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  position    String?
  department  String?
  avatar      String?
  address     Json?
  birthDate   DateTime?
  linkedin    String?
  description String?
  isPrimary   Boolean   @default(false)
  tenantId    String
  companyId   String?
  ownerId     String?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner         User?          @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deals         Deal[]
  tasks         Task[]
  noteRecords   Note[]
  files         File[]
  activities    Activity[]
  leads         Lead[]
  quotes        Quote[]
  contracts     Contract[]
  customers     Customer[]
  conversations Conversation[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([companyId])
  @@index([ownerId])
  @@index([email])
  @@index([deletedAt])
  @@map("contacts")
}

model Lead {
  id          String     @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  companyName String?
  position    String?
  source      LeadSource @default(OTHER)
  sourceInfo  String?
  status      LeadStatus @default(NEW)
  score       Int?
  description String?
  value       Decimal?   @db.Decimal(15, 2)
  convertedAt DateTime?
  tenantId    String
  companyId   String?
  contactId   String?
  ownerId     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner       User?    @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks       Task[]
  noteRecords Note[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([email])
  @@index([deletedAt])
  @@map("leads")
}

model Customer {
  id            String    @id @default(uuid())
  name          String
  email         String?
  phone         String?
  type          String    @default("individual")
  document      String?
  address       Json?
  notes         String?
  lifetimeValue Decimal?  @db.Decimal(15, 2)
  tenantId      String
  contactId     String?
  ownerId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner     User?      @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deals     Deal[]
  contracts Contract[]
  quotes    Quote[]

  @@index([tenantId])
  @@index([contactId])
  @@index([email])
  @@index([deletedAt])
  @@map("customers")
}

// ═══════════════════════════════════════
// SALES
// ═══════════════════════════════════════

model Pipeline {
  id          String    @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  stages PipelineStage[]
  deals  Deal[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?
  sortOrder   Int      @default(0)
  probability Int      @default(0)
  isWon       Boolean  @default(false)
  isLost      Boolean  @default(false)
  pipelineId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Deal {
  id              String       @id @default(uuid())
  title           String
  description     String?
  value           Decimal?     @db.Decimal(15, 2)
  currency        DealCurrency @default(BRL)
  status          DealStatus   @default(OPEN)
  priority        TaskPriority @default(MEDIUM)
  expectedCloseAt DateTime?
  wonAt           DateTime?
  lostAt          DateTime?
  lostReason      String?
  tenantId        String
  pipelineId      String?
  stageId         String?
  companyId       String?
  contactId       String?
  customerId      String?
  ownerId         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  pipeline      Pipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stage         PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  owner         User?          @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  tasks         Task[]
  notes         Note[]
  activities    Activity[]
  files         File[]
  quotes        Quote[]
  contracts     Contract[]
  products      DealProduct[]
  conversations Conversation[]

  @@index([tenantId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([ownerId])
  @@index([status])
  @@index([expectedCloseAt])
  @@index([deletedAt])
  @@map("deals")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  sku         String?
  description String?
  price       Decimal?  @db.Decimal(15, 2)
  cost        Decimal?  @db.Decimal(15, 2)
  unit        String    @default("unit")
  isActive    Boolean   @default(true)
  tenantId    String
  categoryId  String?
  ownerId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  category Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  owner    User?         @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  quoteItems QuoteItem[]
  deals       DealProduct[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([sku])
  @@map("products")
}

model DealProduct {
  dealId    String
  productId String
  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([dealId, productId])
  @@map("deal_products")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String
  description String?
  parentId    String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  parent   Category?  @relation("CatHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CatHierarchy")
  products Product[]

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

model Quote {
  id                      String       @id @default(uuid())
  number                  String
  title                   String?
  description             String?
  status                  QuoteStatus  @default(DRAFT)
  currency                DealCurrency @default(BRL)
  subtotal                Decimal?     @db.Decimal(15, 2)
  discount                Decimal?     @db.Decimal(15, 2)
  discountPercent         Decimal?     @db.Decimal(5, 2)
  taxes                   Decimal?     @db.Decimal(15, 2)
  shipping                Decimal?     @db.Decimal(15, 2)
  totalAmount             Decimal?     @db.Decimal(15, 2)
  margin                  Decimal?     @db.Decimal(5, 2)
  paymentTerms            String?
  commercialConditions    String?
  internalNotes           String?
  customerNotes           String?
  issuedAt                DateTime?
  validUntil              DateTime?
  isFavorite              Boolean      @default(false)
  isArchived              Boolean      @default(false)
  tags                    String[]
  metadata                Json?
  tenantId                String
  dealId                  String?
  companyId               String?
  contactId               String?
  customerId              String?
  ownerId                 String?
  teamId                  String?
  createdBy               String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  deletedAt               DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  deal        Deal?           @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company     Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
