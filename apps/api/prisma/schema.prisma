  createdBy  String?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([version])
  @@index([tenantId])
  @@map("contract_versions")
}

model ContractSigner {
