// MESSAGING
// ═══════════════════════════════════════

model Conversation {
  id                 String      @id @default(uuid())
  subject            String?
  channel            ChannelType
  status             String      @default("active")
  priority           String      @default("normal")
  tags               String[]
  unreadCount        Int         @default(0)
  lastMessageAt      DateTime?
  lastMessagePreview String?
  assignedToId       String?
  teamId             String?
  queueId            String?
  slaStatus          String      @default("in_time")
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  metadata           Json?
  tenantId           String
  userId             String?
  contactId          String?
  dealId             String?
  companyId          String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  tenant       Tenant                    @relation(fields: [tenantId], references: [id])
  user         User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact      Contact?                  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal         Deal?                     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  messages     Message[]
  notes        ConversationNote[]
  assignments  ConversationAssignment[]
  participants ConversationParticipant[]

  @@index([tenantId])
  @@index([userId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@index([queueId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  content        String?
  direction      MessageDirection @default(INBOUND)
  channel        ChannelType
  messageType    String           @default("text")
  externalId     String?
  metadata       Json?
  replyToId      String?
  conversationId String
  senderId       String?
  senderName     String?
  status         String           @default("sent")
  readAt         DateTime?
  deliveredAt    DateTime?
  tenantId       String
  createdAt      DateTime         @default(now())

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?               @relation("SenderMessages", fields: [senderId], references: [id], onDelete: SetNull)
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  attachments  MessageAttachment[]
  reactions    MessageReaction[]
  replyTo      Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]           @relation("MessageReplies")

  @@unique([externalId, tenantId, channel], name: "unique_message_external_tenant_channel")
  @@index([conversationId])
  @@index([tenantId])
  @@index([createdAt])
  @@map("messages")
}

model Channel {
  id            String      @id @default(uuid())
  type          ChannelType
  name          String
  credentials   Json?
  config        Json?
  isActive      Boolean     @default(true)
  isConnected   Boolean     @default(false)
  webhookUrl    String?
  webhookSecret String?
  healthScore   String      @default("unknown")
  tenantId      String
  createdAt     DateTime    @default(now())
