  location    String?
  isCompleted Boolean      @default(false)
  tenantId    String
  userId      String?
  contactId   String?
  dealId      String?
  companyId   String?
  quoteId     String?
  contractId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
