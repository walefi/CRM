  filters     Json?
  preview     String?
  isActive    Boolean  @default(true)
  tenantId    String
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
  @@index([type])
  @@map("report_templates")
}

model ReportExport {
  id          String   @id @default(uuid())
  executionId String
  format      String
  outputUrl   String?
  fileData    String?
  fileSize    Int?
  status      String   @default("pending")
  error       String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([executionId])
  @@index([status])
  @@map("report_exports")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  type      String   @default("info")
  url       String?
  isRead    Boolean  @default(false)
  tenantId  String
  userId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════
// WORKFLOW ENGINE
// ═══════════════════════════════════════

model Workflow {
  id          String         @id @default(uuid())
  name        String
  description String?
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  nodes       Json           @default("[]")
  edges       Json           @default("[]")
  config      Json?
  tags        String[]
  isTemplate  Boolean        @default(false)
  templateCategory String?
  tenantId    String
  createdBy   String?
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  versions   WorkflowVersion[]
  executions WorkflowExecution[]

  @@index([tenantId])
  @@index([status])
  @@index([isTemplate])
  @@index([deletedAt])
  @@map("workflows")
}

model WorkflowVersion {
  id         String   @id @default(uuid())
  workflowId String
  version    Int
  data       Json
  reason     String?
  tenantId   String
  createdBy  String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@index([workflowId])
  @@index([version])
  @@index([tenantId])
  @@map("workflow_versions")
}

model WorkflowExecution {
  id           String                 @id @default(uuid())
  status       WorkflowExecutionStatus @default(PENDING)
  trigger      String?
  input        Json?
  output       Json?
  error        String?
  nodeResults  Json?
  correlationId String?
  startedAt    DateTime?
  completedAt  DateTime?
  duration     Int?
  workflowId   String
  tenantId     String
  createdBy    String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@index([workflowId])
  @@index([tenantId])
  @@index([status])
  @@index([correlationId])
  @@index([createdAt])
  @@map("workflow_executions")
}

// ═══════════════════════════════════════
// EVENT BUS / EVENT STORE
// ═══════════════════════════════════════

model EventStore {
  id             String      @id @default(uuid())
  eventName      String
  eventType      String
  aggregateId    String?
  aggregateType  String?
  payload        Json
  metadata       Json?
  status         EventStatus @default(PENDING)
  retryCount     Int         @default(0)
  maxRetries     Int         @default(3)
  correlationId  String?
  causationId    String?
  version        Int         @default(1)
  origin         String?
  error          String?
  processedAt    DateTime?
  tenantId       String
  userId         String?
  createdAt      DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventName])
  @@index([status])
  @@index([correlationId])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
  @@map("event_store")
}

model EventOutbox {
  id           String  @id @default(uuid())
  eventId      String
  eventName    String
  payload      Json
  metadata     Json?
  status       String  @default("pending")
  error        String?
  processedAt  DateTime?
  publisherId  String?
  createdAt    DateTime @default(now())

  @@index([eventId])
  @@index([status])
  @@index([createdAt])
  @@map("event_outbox")
}

model DeadLetter {
  id             String   @id @default(uuid())
  eventId        String
  eventName      String
  payload        Json
  metadata       Json?
  error          String?
  retryCount     Int      @default(0)
  maxRetries     Int      @default(5)
  lastRetryAt    DateTime?
  resolvedAt     DateTime?
  resolution     String?
  resolvedById   String?
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventId])
  @@index([resolvedAt])
  @@index([createdAt])
  @@map("dead_letters")
}

// ═══════════════════════════════════════
// SEARCH ENGINE
// ═══════════════════════════════════════

enum SearchProvider {
  POSTGRESQL
  ELASTICSEARCH
  OPENSEARCH
  MEILISEARCH
  ALGOLIA
}

model SearchIndex {
  id             String         @id @default(uuid())
  entityType     String
  entityId       String
  title          String
  subtitle       String?
  content        String
  searchVector   String?
  tags           String[]
  metadata       Json?
  url            String?
  score          Float          @default(0)
  isActive       Boolean        @default(true)
  indexedAt      DateTime       @default(now())
  reindexedAt    DateTime?
  tenantId       String
  createdBy      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id])
  document SearchDocument[]

  @@unique([entityType, entityId])
  @@index([tenantId])
  @@index([entityType])
  @@index([title])
  @@index([tags])
  @@index([score])
  @@index([indexedAt])
  @@map("search_indexes")
}

model SearchDocument {
  id            String      @id @default(uuid())
  entityType    String
  entityId      String
  title         String
  subtitle      String?
  contentPreview String?
  tags          String[]
  url           String?
  thumbnail     String?
  status        String      @default("active")
  metadata      Json?
  indexId       String?
  tenantId      String
  createdBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  index  SearchIndex? @relation(fields: [indexId], references: [id])
  tenant Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([entityType])
  @@index([entityId])
  @@index([title])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("search_documents")
}

model SearchHistory {
  id            String   @id @default(uuid())
  query         String
  filters       Json?
  resultCount   Int      @default(0)
  durationMs    Int?
  userId        String
  tenantId      String
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([query])
  @@index([createdAt])
  @@map("search_history")
}

model SearchFavorite {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  title         String
  url           String?
  userId        String
  tenantId      String
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, entityType, entityId])
  @@index([tenantId])
  @@index([userId])
  @@index([entityType])
  @@map("search_favorites")
}

model SearchSavedFilter {
  id          String   @id @default(uuid())
  name        String
  filters     Json
  userId      String
  tenantId    String
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([name])
  @@map("search_saved_filters")
}

// ═══════════════════════════════════════
// ANALYTICS ENGINE
// ═══════════════════════════════════════

enum MetricType {
  COUNT
  SUM
  AVERAGE
  MEDIAN
  MAX
  MIN
  PERCENTAGE
  RATE
  DURATION
  FUNNEL
  RANKING
  TREND
}

enum DashboardCategory {
  COMMERCIAL
  FINANCE
  MARKETING
  SUPPORT
  OPERATIONS
  EXECUTIVE
  ADMIN
  USER
}

model AnalyticsEvent {
  id            String   @id @default(uuid())
  eventName     String
  entityType    String?
  entityId      String?
  payload       Json
  metadata      Json?
  tenantId      String
  userId        String?
  correlationId String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([eventName])
  @@index([entityType])
  @@index([createdAt])
  @@map("analytics_events")
}

model MetricSnapshot {
  id            String     @id @default(uuid())
  metricKey      String
  metricType    MetricType
  metricName    String
  entityType    String?
  value         Float
  previousValue Float?
  changePercent Float?
  trend         Json?
  period        String     @default("daily")
  periodStart   DateTime
  periodEnd     DateTime?
  metadata      Json?
  tenantId      String
  createdAt     DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([metricKey])
  @@index([period])
  @@index([periodStart])
  @@index([createdAt])
  @@map("metric_snapshots")
}

model DashboardTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   @default("USER")
  config      Json     @default("{}")
  widgets     Json     @default("[]")
  isActive    Boolean  @default(true)
  tenantId    String
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
  @@map("dashboard_templates")
}
