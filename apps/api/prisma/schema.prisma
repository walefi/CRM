  message      String
  details      Json?
  automationId String
  executionId  String?
  tenantId     String
  userId       String?
  createdAt    DateTime           @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@index([automationId])
  @@index([tenantId])
  @@index([level])
  @@index([createdAt])
  @@map("automation_logs")
}

