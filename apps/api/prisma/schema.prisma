// ══════════════════════════════════════════════
// CRM Enterprise — Complete Database Schema
// ══════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
  PENDING
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum DealStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  LANDING_PAGE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  REFERRAL
  SOCIAL_MEDIA
  EMAIL_MARKETING
  COLD_CALL
  TRADE_SHOW
  PARTNER
  EMAIL
  MANUAL
  OTHER
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  NOTE
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DealCurrency {
  BRL
  USD
  EUR
  GBP
  JPY
  CNY
}

enum AutomationStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ERROR
  PAUSED
  RUNNING
}

enum TriggerType {
  DEAL_CREATED
  DEAL_UPDATED
  LEAD_CREATED
  LEAD_CONVERTED
  TASK_COMPLETED
  CONTACT_CREATED
  FORM_SUBMITTED
  WEBHOOK
  SCHEDULED
  COMPANY_CREATED
  CONTRACT_SIGNED
  DOCUMENT_SENT
