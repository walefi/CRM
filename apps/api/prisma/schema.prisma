  createdAt   DateTime @default(now())

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("sales_order_items")
}

model SalesOrderHistory {
  id        String   @id @default(uuid())
  orderId   String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("sales_order_history")
}

