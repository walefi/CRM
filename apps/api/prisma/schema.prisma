  USER_CREATED
  LOGIN
  CRON
  MANUAL
  API
  LEAD_UPDATED
  DEAL_WON
  DEAL_LOST
  PRODUCT_CREATED
  CONTRACT_CREATED
  CONTRACT_EXPIRING
  CONTRACT_RENEWED
  QUOTE_SENT
  QUOTE_ACCEPTED
  DOCUMENT_SHARED
  ACTIVITY_COMPLETED
  NOTIFICATION_SENT
  WORKFLOW_COMPLETED
  LOGOUT
  WEBHOOK_RECEIVED
  API_CALLED
  CUSTOM_EVENT
}

enum ActionType {
  SEND_EMAIL
  CREATE_TASK
  UPDATE_DEAL
  SEND_NOTIFICATION
  WEBHOOK
  UPDATE_CONTACT
  MOVE_PIPELINE
  CREATE_LEAD
  CREATE_CONTACT
  CREATE_COMPANY
  CREATE_DEAL
  CREATE_ACTIVITY
  SEND_WHATSAPP
  SEND_PUSH
  CREATE_DOCUMENT
  UPDATE_FIELDS
  EXECUTE_AI
  EXECUTE_API
  CREATE_PRODUCT
  SEND_SMS
  EXECUTE_WORKFLOW
  CREATE_TIMELINE
  CREATE_AUDIT
  CREATE_COMMENT
  CREATE_TAG
  ADD_FILE
  EXECUTE_SCRIPT
}

enum ScheduleFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CRON
  INTERVAL
  AFTER_EVENT
}

enum AutomationLogLevel {
  INFO
  WARN
  ERROR
  DEBUG
  TRACE
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  GREATER_THAN
  LESS_THAN
  GREATER_OR_EQUAL
  LESS_OR_EQUAL
  CONTAINS
  NOT_CONTAINS
  STARTS_WITH
  ENDS_WITH
